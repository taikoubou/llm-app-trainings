# === 1. ベクトルデータベース（絶対除外！） ===
# ここにはアップロードしたPDFの生テキストやベクトルデータが入っているため、
# GitHubに上げると容量オーバー＆プライバシー侵害になります。
chroma_db/
*.db

# === 2. Pythonの仮想環境（絶対除外！） ===
# ライブラリの実体が入っているフォルダです。容量が数GBあるので除外します。
.venv/
venv/
ENV/
__pycache__/
*.pyc

# === 3. アップロードされたPDFの保管場所（もしあれば） ===
# ユーザーが検証用にアップロードしたPDFファイル自体を除外します。
*.pdf
data/
uploads/

# === 4. 環境設定ファイル（APIキーなど用） ===
# 将来的にOpenAIのAPIキーなどを使うようになった時のために、先んじて隠します。
.env

# === 5. Mac特有のゴミファイル ===
.DS_Store

.ruff_cache/

*.egg-info/
build/
dist/
